// SGD-GADPR-LM — MySQL/MariaDB (XAMPP). Ver docs/04-modelo-base-de-datos.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Cuentas de aplicación (credenciales Argon2id en capa auth, ETAPA 3).
model User {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  nombres      String?  @db.VarChar(120)
  apellidos    String?  @db.VarChar(120)
  dependenciaId String? @map("dependencia_id")
  cargoId       String? @map("cargo_id")
  activo       Boolean  @default(true)
  /// Incrementa con contraseña incorrecta; se resetea en login OK o tras desbloqueo por tiempo.
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  /// Si está en futuro, el login debe rechazar (además del throttling por IP).
  lockedUntil DateTime? @map("locked_until")
  /// Último inicio de sesión exitoso con contraseña (no actualiza solo por refresh silencioso).
  ultimoLoginAt DateTime? @map("ultimo_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles         UserRole[]
  /// Permisos otorgados directamente al usuario (unión con permisos de roles en runtime).
  directPermissions UserPermission[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  dependencia   Dependencia? @relation(fields: [dependenciaId], references: [id], onDelete: SetNull)
  cargo         Cargo?       @relation(fields: [cargoId], references: [id], onDelete: SetNull)
  Documento     Documento[]
  DocumentoEvento DocumentoEvento[]
  DocumentoArchivo DocumentoArchivo[]
  DocumentoArchivoEvento DocumentoArchivoEvento[]
  auditLogs     AuditLog[]
  updatedSecurityPolicies SecurityPolicy[] @relation("SecurityPolicyUpdatedBy")
  documentoUserAccess DocumentoUserAccess[]
  documentoUserAccessCreatedBy DocumentoUserAccess[] @relation("DocumentoUserAccessCreatedBy")
  documentoRoleAccessCreatedBy DocumentoRoleAccess[] @relation("DocumentoRoleAccessCreatedBy")

  @@index([dependenciaId])
  @@index([cargoId])
  @@map("users")
}

/// Refresh opaco (hash SHA-256 en BD); el valor en claro solo en cookie HttpOnly.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastUsedAt])
  @@map("refresh_tokens")
}

/// Token de recuperación de credenciales (flujo "olvidé mi contraseña").
/// - Se almacena solo el hash SHA-256 del token (nunca el token en claro).
/// - El token es de un solo uso (`used_at`) y puede revocarse (`revoked_at`).
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  revokedAt DateTime? @map("revoked_at")
  requestedIp String? @map("requested_ip") @db.VarChar(64)
  userAgent  String?  @map("user_agent") @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

/// Auditoría transversal (seguridad/administración). No reemplaza eventos por dominio.
model AuditLog {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now()) @map("created_at")

  actorUserId   String?  @map("actor_user_id")
  actorEmail    String?  @map("actor_email") @db.VarChar(255)

  action        String   @db.VarChar(64)
  result        String   @db.VarChar(16) // OK | FAIL

  resourceType  String?  @map("resource_type") @db.VarChar(64)
  resourceId    String?  @map("resource_id") @db.VarChar(64)

  ip            String?  @db.VarChar(64)
  userAgent     String?  @map("user_agent") @db.VarChar(255)
  correlationId String?  @map("correlation_id") @db.VarChar(64)
  metaJson      String?  @map("meta_json") @db.Text

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

/// Política institucional de seguridad (registro ISO 15489).
/// - Persistida en BD para evidencia y gobierno (no necesariamente altera runtime si no está implementado).
/// - Singleton por entorno: id fijo "default".
model SecurityPolicy {
  id String @id @default("default") @db.VarChar(64)

  // Autenticación (ISO 27001 A.5.17 / OWASP ASVS V2)
  desiredPasswordMinLength   Int  @default(8) @map("desired_password_min_length")
  desiredLockoutEnabled      Boolean @default(true) @map("desired_lockout_enabled")
  desiredLockoutMaxAttempts  Int  @default(5) @map("desired_lockout_max_attempts")
  desiredLockoutMinutes      Int  @default(20) @map("desired_lockout_minutes")

  // Sesión (referencial; JWT stateless, evidencia en config/env)
  desiredJwtAccessExpiresIn  String @default("15m") @map("desired_jwt_access_expires_in") @db.VarChar(16)
  desiredRefreshSessionDays  Int    @default(7) @map("desired_refresh_session_days")

  // Controles adicionales (pueden quedar en "pendiente" según implementación)
  desiredPasswordHistoryCount Int @default(0) @map("desired_password_history_count")
  desiredAdminStepUpAuth      Boolean @default(false) @map("desired_admin_step_up_auth")

  notes String? @db.VarChar(800)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedByUserId String? @map("updated_by_user_id")
  updatedBy User? @relation("SecurityPolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedAt])
  @@map("security_policy")
}

model Role {
  id          String   @id @default(uuid())
  codigo      String   @unique @db.VarChar(64)
  nombre      String   @db.VarChar(120)
  descripcion String?  @db.VarChar(500)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]
  documentoAccess DocumentoRoleAccess[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  codigo      String   @unique @db.VarChar(128)
  descripcion String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]
  usersDirect UserPermission[]

  @@map("permissions")
}

/// Permisos adicionales por usuario (`Permission` directo), además de los heredados por `UserRole`.
model UserPermission {
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Unidad organizativa (catálogo ETAPA 5).
model Dependencia {
  id          String   @id @default(uuid())
  codigo      String   @unique @db.VarChar(32)
  nombre      String   @db.VarChar(200)
  descripcion String?  @db.VarChar(500)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cargos    Cargo[]
  users     User[]
  documentos Documento[]

  @@map("dependencias")
}

/// Cargo / puesto (catálogo ETAPA 5); dependencia opcional.
model Cargo {
  id            String   @id @default(uuid())
  codigo        String   @unique @db.VarChar(32)
  nombre        String   @db.VarChar(200)
  descripcion   String?  @db.VarChar(500)
  dependenciaId String?  @map("dependencia_id")
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dependencia Dependencia? @relation(fields: [dependenciaId], references: [id], onDelete: SetNull)
  users       User[]

  @@index([dependenciaId])
  @@map("cargos")
}

/// Tipología documental (catálogo ETAPA 5).
model TipoDocumental {
  id          String      @id @default(uuid())
  codigo      String      @unique @db.VarChar(32)
  nombre      String      @db.VarChar(200)
  descripcion String?     @db.VarChar(500)
  activo      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  Documento   Documento[]

  @@map("tipos_documentales")
}

/// Serie documental (catálogo ETAPA 5).
model Serie {
  id          String   @id @default(uuid())
  codigo      String   @unique @db.VarChar(32)
  nombre      String   @db.VarChar(200)
  descripcion String?  @db.VarChar(500)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subseries Subserie[]

  @@map("series")
}

/// Subserie documental (catálogo ETAPA 5).
model Subserie {
  id          String   @id @default(uuid())
  serieId     String   @map("serie_id")
  codigo      String   @unique @db.VarChar(32)
  nombre      String   @db.VarChar(200)
  descripcion String?  @db.VarChar(500)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  serie     Serie       @relation(fields: [serieId], references: [id], onDelete: Restrict)
  Documento Documento[]

  @@index([serieId])
  @@map("subseries")
}

/// Documento registrado (ETAPA 6 — MVP).
model Documento {
  id                       String   @id @default(uuid())
  codigo                   String   @unique @db.VarChar(64)
  asunto                   String   @db.VarChar(250)
  descripcion              String?  @db.VarChar(1000)
  fechaDocumento           DateTime @map("fecha_documento")
  /// Ciclo de vida (catálogo y transiciones en `documento-estado.util.ts`).
  estado                   String   @default("REGISTRADO") @db.VarChar(32)
  nivelConfidencialidad    String   @default("INTERNO") @map("nivel_confidencialidad") @db.VarChar(32)
  activo                   Boolean  @default(true)
  tipoDocumentalId         String   @map("tipo_documental_id")
  subserieId               String   @map("subserie_id")
  dependenciaId            String?  @map("dependencia_id")
  /// Política de acceso: INHERIT = reglas actuales; RESTRICTED = solo ACL (y ADMIN) + creador.
  accessPolicy             String   @default("INHERIT") @map("access_policy") @db.VarChar(16)
  createdById              String   @map("created_by_id")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  tipoDocumental TipoDocumental @relation(fields: [tipoDocumentalId], references: [id], onDelete: Restrict)
  subserie       Subserie       @relation(fields: [subserieId], references: [id], onDelete: Restrict)
  dependencia    Dependencia?    @relation(fields: [dependenciaId], references: [id], onDelete: SetNull)
  createdBy      User           @relation(fields: [createdById], references: [id], onDelete: Restrict)
  eventos        DocumentoEvento[]
  archivos       DocumentoArchivo[]
  userAccess     DocumentoUserAccess[]
  roleAccess     DocumentoRoleAccess[]

  @@index([tipoDocumentalId])
  @@index([subserieId])
  @@index([createdById])
  @@index([dependenciaId])
  @@index([nivelConfidencialidad])
  @@index([accessPolicy])
  @@map("documentos")
}

/// ACL por documento (usuario). Solo aplica si `Documento.accessPolicy = RESTRICTED`.
model DocumentoUserAccess {
  documentoId String @map("documento_id")
  userId      String @map("user_id")
  access      String @default("READ") @db.VarChar(16)
  createdById String @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  documento Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy User      @relation("DocumentoUserAccessCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@id([documentoId, userId])
  @@index([userId])
  @@index([createdById])
  @@map("documento_user_access")
}

/// ACL por documento (rol). Solo aplica si `Documento.accessPolicy = RESTRICTED`.
model DocumentoRoleAccess {
  documentoId String @map("documento_id")
  roleId      String @map("role_id")
  access      String @default("READ") @db.VarChar(16)
  createdById String @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  documento Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdBy User      @relation("DocumentoRoleAccessCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@id([documentoId, roleId])
  @@index([roleId])
  @@index([createdById])
  @@map("documento_role_access")
}

/// Evento de trazabilidad del documento (ETAPA 6).
model DocumentoEvento {
  id          String   @id @default(uuid())
  documentoId String   @map("documento_id")
  tipo        String   @db.VarChar(32)
  cambiosJson String?  @map("cambios_json") @db.Text
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  documento Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([documentoId])
  @@index([createdById])
  @@map("documento_eventos")
}

/// Archivo adjunto a un documento (ETAPA 7).
model DocumentoArchivo {
  id           String   @id @default(uuid())
  documentoId  String   @map("documento_id")
  version      Int      @default(1)
  originalName String   @map("original_name") @db.VarChar(255)
  storedName   String   @map("stored_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(127)
  sizeBytes    Int      @map("size_bytes")
  sha256       String   @db.VarChar(64)
  pathRel      String   @map("path_rel") @db.VarChar(500)
  activo       Boolean  @default(true)
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  documento Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  eventos   DocumentoArchivoEvento[]

  @@index([documentoId])
  @@index([createdById])
  @@unique([documentoId, originalName, version])
  @@map("documento_archivos")
}

/// Evento de trazabilidad del archivo (ETAPA 7).
model DocumentoArchivoEvento {
  id                String   @id @default(uuid())
  documentoArchivoId String  @map("documento_archivo_id")
  tipo              String   @db.VarChar(32)
  metaJson          String?  @map("meta_json") @db.Text
  createdById       String   @map("created_by_id")
  createdAt         DateTime @default(now()) @map("created_at")

  archivo   DocumentoArchivo @relation(fields: [documentoArchivoId], references: [id], onDelete: Cascade)
  createdBy User             @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([documentoArchivoId])
  @@index([createdById])
  @@map("documento_archivo_eventos")
}
