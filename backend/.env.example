# Copiar a .env y ajustar valores. No commitear .env con secretos reales.

# API
PORT=3000

# MySQL/MariaDB (XAMPP) — Prisma
# Crear la base en phpMyAdmin antes de migrar (ej. gestion_documental_gadpr_lm)
DATABASE_URL="mysql://root:@127.0.0.1:3306/gestion_documental_gadpr_lm"

# JWT acceso (HS256) — generar secretos largos aleatorios; rotar si se filtran
JWT_ACCESS_SECRET=change-me-access
# Duración del access token (ej. 15m, 1h). Ver formato en documentación de jsonwebtoken
JWT_ACCESS_EXPIRES=15m

# Refresh en cookie HttpOnly: días de vida del refresh opaco y nombre de cookie
JWT_REFRESH_DAYS=7
REFRESH_COOKIE_NAME=sgd_refresh

# Inactividad (ASVS V3): si no se llama a /auth/refresh en este lapso, el refresh se revoca.
# Valor en minutos. Por defecto 10080 (7 días) si no se define.
SESSION_INACTIVITY_MINUTES=10080

# Opcional: firma de refresh si en el futuro se usa JWT para refresh (actualmente opaco + hash en BD)
JWT_REFRESH_SECRET=change-me-refresh

# Bloqueo por cuenta tras intentos fallidos de contraseña (además del @Throttle por IP en /auth/login)
# AUTH_LOCKOUT_MAX_ATTEMPTS=5
# AUTH_LOCKOUT_MINUTES=15

# Seed único (después de migraciones): npx prisma db seed
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=Admin123!

# CORS: origen del frontend Vite (añadir URL ngrok solo durante demos temporales)
CORS_ORIGIN=http://localhost:5173

# --- Correo SMTP (recuperación de contraseña) ---
# Si defines SMTP_HOST (o SMTP_SERVER) y SMTP_FROM_EMAIL, el backend envía el enlace por correo.
# Descomenta y rellena en tu .env local (no subas secretos al repositorio).
# SMTP_HOST=smtp.institucion.gob.ec
# SMTP_PORT=587
# true = TLS implícito (típ. 465). Con 587 suele ser false + STARTTLS
# SMTP_SECURE=false
# SMTP_USER=cuenta-servicio
# SMTP_PASSWORD=secreto-solo-env-local
# SMTP_FROM_EMAIL=no-reply@institucion.gob.ec
# SMTP_FROM_NAME=SGD GADPR-LM

# URL pública del navegador hacia el frontend (sin barra final). Por defecto: primer origen en CORS o localhost.
# PASSWORD_RESET_FRONTEND_URL=http://localhost:5173
# PASSWORD_RESET_PATH=/restablecer

# Nombre público opcional para asunto/cuerpo del mensaje.
# APP_PUBLIC_NAME=SGD GADPR-LM

# En desarrollo sin SMTP, el JSON puede incluir debugToken si PASSWORD_RESET_DEBUG_TOKEN no es "false"
# PASSWORD_RESET_DEBUG_TOKEN=true

# Minutos de validez del enlace cuando un ADMIN crea usuario e invita por correo (token en password_reset_tokens)
# USER_INVITE_MINUTES=4320
